# ----------------------------------------------------------------------------
# MemoryWiki environment. Copy to `.env` then `docker compose up -d`.
# Everything below has a working default so the stack runs OFFLINE with no keys.
# ----------------------------------------------------------------------------

# LLM provider: "Deterministic" (no key, offline) or "OpenAI"
LLM__PROVIDER=Deterministic
OPENAI__APIKEY=
OPENAI__MODEL=gpt-4o-mini
OPENAI__BASEURL=https://api.openai.com/v1

# PostgreSQL
POSTGRES_USER=memorywiki
POSTGRES_PASSWORD=memorywiki
POSTGRES_DB=memorywiki

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=memorywiki

# JWT signing key (CHANGE in production; min 32 chars)
JWT__SIGNINGKEY=super-secret-development-signing-key-change-me-please-32+
JWT__ISSUER=memorywiki
JWT__AUDIENCE=memorywiki-clients
